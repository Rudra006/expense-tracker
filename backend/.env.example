cd backend && cp .env.example .env # Copy this file to .env and fill in your values

# MongoDB connection string
# Local:   mongodb://localhost:27017/expense-tracker
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/expense-tracker
MONGODB_URI=mongodb://localhost:27017/expense-tracker

# Server port
PORT=5000

# JWT secret — use a long random string in production (e.g. openssl rand -base64 48)
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins
# e.g. http://localhost:5173,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173
